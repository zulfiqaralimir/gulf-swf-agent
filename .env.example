# Google AI / Gemini
GOOGLE_API_KEY=your_gemini_api_key_here

# Google Cloud
GOOGLE_CLOUD_PROJECT=gulf-swf-agent

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/swf_intelligence
MONGODB_DATABASE=swf_intelligence

# SEC EDGAR (required by EDGAR fair-use policy — use your real name + email)
SEC_EDGAR_USER_AGENT=YourName your@email.com

# Frontend (set after Cloud Run deployment)
NEXT_PUBLIC_AGENT_API_URL=https://gulf-swf-agent-xxxx-uc.a.run.app
